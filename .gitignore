# Dataset (images are heavy)
# ──────────────────────────────────────────────
combined_dataset/
combined_dataset.zip

# ──────────────────────────────────────────────
# Trained model weights (reproducible via training)
# ──────────────────────────────────────────────
outputs/*/model.pth
outputs/*/generator.pth
outputs/*/discriminator.pth
outputs/*/*.pth

# ──────────────────────────────────────────────
# Evaluation outputs (reproducible via evaluate.py)
# ──────────────────────────────────────────────
outputs/*/evaluation/

# ──────────────────────────────────────────────
# Generated figures
# ──────────────────────────────────────────────
figures/

