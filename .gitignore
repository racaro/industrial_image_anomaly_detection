# ──────────────────────────────────────────────
# Python
# ──────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so

# ──────────────────────────────────────────────
# Virtual environment
# ──────────────────────────────────────────────
.venv/
venv/
ENV/

